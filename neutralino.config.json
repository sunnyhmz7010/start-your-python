{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.startyourpython.app",
  "version": "1.1.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/build/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "debug.*",
    "filesystem.*",
    "storage.*",
    "window.*",
    "events.*"
  ],
  "globalVariables": {
    "appName": "Start Your Python"
  },
  "modes": {
    "window": {
      "title": "Start Your Python",
      "width": 1400,
      "height": 900,
      "minWidth": 1000,
      "minHeight": 700,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/appIcon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "StartYourPython",
    "resourcesPath": "/build/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "5.0.0",
    "clientVersion": "5.0.0",
    "defaultLibraryPath": "/resources/js/neutralino.js"
  }
}
