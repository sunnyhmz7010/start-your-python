{
  "name": "start-your-python",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:Path += ';' + (Join-Path $env:USERPROFILE '.cargo\\bin'); tauri dev\"",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:Path += ';' + (Join-Path $env:USERPROFILE '.cargo\\bin'); tauri build --no-bundle\"",
    "tauri:bundle": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:Path += ';' + (Join-Path $env:USERPROFILE '.cargo\\bin'); tauri build\"",
    "tauri:release": "npm run tauri:build && powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\package-windows-release.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "vue": "^3.4.21",
    "pinia": "^2.1.7",
    "vue-router": "^4.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/theme-one-dark": "^6.1.2",
    "codemirror": "^6.0.1",
    "marked": "^12.0.2",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.6"
  }
}
